{# Root base for all OSWIS e-mail templates.

Child templates override blocks (content_header_inner / content_inner /
content_footer_inner / message_message_inner / etc.) and the parent compiles
the result via the `mjml_to_html` Twig filter (Node `mjml` CLI behind a cache).

The set-statements below mirror the legacy inky version: leaf templates and
the calling PHP context can pre-seed `f` (formal vs informal Czech),
`a` (czech gender suffix), `salName` (vocative salutation), and the parent
falls back to whatever is reachable on the bound `contact` / `appUser`.
#}
{% set f = f is defined ? f : (contact.formal|default(appUser.formal|default(true))) %}
{% set a = a is defined ? a : (contact.czechSuffixA|default(appUser.czechSuffixA|default(''))) %}
{% set salName = salutationName|default(contact.salutationName|default(appUser.salutationName|default)) %}

{% apply mjml_to_html %}
<mjml>
    <mj-head>
        <mj-title>{% block html_title %}{{ email.subject|default('Zpráva z ' ~ oswis.app.name|default('OSWIS')) }}{% endblock %}</mj-title>
        <mj-preview>{% block html_preview %}{{ block('html_title') }}{% endblock %}</mj-preview>
        <mj-attributes>
            <mj-all font-family="Ubuntu, Helvetica, Arial, sans-serif" />
            <mj-text font-size="14px" line-height="1.5" color="#103010" padding="10px 20px" />
            <mj-section padding="0" />
            <mj-button background-color="#006FAD" color="#ffffff" font-weight="700" border-radius="4px" />
        </mj-attributes>
        <mj-style inline="inline">
            a { text-decoration: none; }
            a:hover { text-decoration: underline; }
            h2, h3, h4 { color: #006FAD; font-weight: bold; margin-top: 0.8em; margin-bottom: 0.4em; }
            h2 { font-size: 1.7em; }
            h3 { font-size: 1.45em; }
            h4 { font-size: 1.3em; }
            small { color: #606060; }
            .warning { color: red; font-weight: bold; }
            .error-box {
                display: block; width: 100%; color: red; border: 2px solid red;
                background-color: #f08080; padding: 0.5em 1em; margin: 0.5em 0;
            }
            .token-box {
                display: block; width: 100%; text-align: center;
                border: 1px solid lightgrey; background-color: rgba(0, 111, 173, 0.1);
                padding: 0.5em 1em; margin-top: 0.3em; word-break: break-all;
                font-family: monospace; font-size: 0.85em;
            }
        </mj-style>
    </mj-head>

    <mj-body background-color="#f5f5f5">
        {% block header_outer %}
            <mj-section background-color="#ffffff" padding="20px 0">
                {% block header_inner %}
                    <mj-column>
                        {% block header_logo %}
                            {% if logo_disabled is defined and logo_disabled %}
                            {% elseif logo_src is defined and logo_src %}
                                <mj-image src="{{ logo_src }}" alt="{{ oswis.app.name }}" width="200px" />
                            {% elseif oswis.app.logo|default %}
                                <mj-text align="center" font-size="22px" font-weight="700" color="#006FAD">{{ oswis.app.name|default('OSWIS') }}</mj-text>
                            {% else %}
                                <mj-text align="center" font-size="22px" font-weight="700" color="#006FAD">{{ oswis.app.name|default('OSWIS') }}</mj-text>
                            {% endif %}
                        {% endblock header_logo %}
                    </mj-column>
                {% endblock header_inner %}
            </mj-section>
        {% endblock header_outer %}

        <mj-section background-color="#ffffff">
            <mj-column>
                {% block content_header_outer %}
                    <mj-text>
                        {% block content_header_inner %}
                            {% if f %}Dobrý den{% else %}Ahoj{% endif %}{{ salName ? ' ' ~ salName : '' }}!
                        {% endblock content_header_inner %}
                    </mj-text>
                {% endblock content_header_outer %}

                {% block content_outer %}
                    <mj-text>
                        {% block content_inner %}
                            <div class="error-box">
                                <p>Nastala chyba při odesílání zprávy a její obsah nebyl načten.</p>
                                <p>Kontaktuj{{ f ? 'te' : '' }} nás, prosím, ať můžeme nastalou situaci co nejrychleji vyřešit.</p>
                                <p style="color:grey;font-weight:normal;">Požadovaná šablona: {{ type|default('neznámá') }}</p>
                            </div>
                        {% endblock content_inner %}
                    </mj-text>
                {% endblock content_outer %}

                {% block content_footer_outer %}
                    <mj-text>
                        {% block content_footer_inner %}
                            V případě nejasností nebo problémů nás neváhej{{ f ? 'te' : '' }} kontaktovat.
                        {% endblock content_footer_inner %}
                    </mj-text>
                {% endblock content_footer_outer %}
            </mj-column>
        </mj-section>

        {% block footer_outer %}
            <mj-section background-color="#ffffff" padding="0 20px 20px">
                <mj-column>
                    <mj-divider border-color="#dddddd" border-width="1px" padding="10px 0" />
                    {% block footer_inner %}
                        <mj-text font-size="11px" color="#888888" align="center">
                            Tento automatický e-mail jsi obdržel{{ a }}, protože se s touto adresou někdo zaregistroval
                            v aplikaci <a href="{{ oswis.app.url|default('#') }}" title="{{ oswis.app.name_long|default(oswis.app.name|default('')) }}">{{ oswis.app.name_short|default(oswis.app.name|default('OSWIS')) }}</a>.
                            Pokud {{ f ? 'jste' : 'jsi' }} to nebyl{{ a }} {{ f ? 'Vy' : 'ty' }}, informuj{{ f ? 'te' : '' }} nás, prosím.
                        </mj-text>
                    {% endblock footer_inner %}
                </mj-column>
            </mj-section>
        {% endblock footer_outer %}
    </mj-body>
</mjml>
{% endapply %}
