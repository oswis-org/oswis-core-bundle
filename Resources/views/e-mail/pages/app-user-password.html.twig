{% extends '@OswisOrgOswisCore/e-mail/pages/app-user.html.twig' %}

{% block html_title %}{{ email.subject|default('Změna hesla u účtu') }}{% endblock %}

{% block content_outer %}
    <mj-text>
        U {{ f ? 'Vašeho' : 'Tvého' }} uživatelského účtu v aplikaci <b>{{ oswis.app.name|default }}</b>
        byl zaznamenán požadavek na změnu přihlašovacího hesla.
    </mj-text>

    {% if type == 'password-change-request' %}
        {% if tokenUrl|default %}
            <mj-button href="{{ tokenUrl }}" background-color="#006FAD" color="#ffffff" font-weight="700" font-size="16px" inner-padding="14px 24px" border-radius="4px">
                Nastavit nové heslo
            </mj-button>
            <mj-text font-size="11px" color="#666666">
                Pokud tlačítko nefunguje, zkopíruj{{ f ? 'te' : '' }} si tuto adresu do prohlížeče:<br>
                <a href="{{ tokenUrl }}" style="color:#006FAD; word-break:break-all;">{{ tokenUrl }}</a>
            </mj-text>
            {% if appUserToken.validHours|default %}
                <mj-text font-size="11px" color="#888888">
                    Odkaz je platný {{ appUserToken.validHours }} hodin od vygenerování.
                </mj-text>
            {% endif %}
        {% else %}
            <mj-text>
                Odkaz pro změnu hesla se z neočekávaných důvodů nepodařilo vygenerovat.
            </mj-text>
            <mj-text font-size="11px" color="#888888">
                Kontaktuj{{ f ? 'te' : '' }} nás, prosím, pro vyřešení situace.
            </mj-text>
        {% endif %}
    {% elseif type == 'password-change' %}
        <mj-text>Nové heslo bylo úspěšně nastaveno.</mj-text>
        {% if appUser.plainPassword|default %}
            <mj-text><strong>Nově nastavené vygenerované heslo:</strong></mj-text>
            <mj-text font-family="monospace" font-size="16px" background-color="#f0f0f0" padding="10px 20px" align="center">
                {{ appUser.plainPassword|default }}
            </mj-text>
        {% endif %}
    {% else %}
        <mj-text>Při zpracování požadavku na změnu hesla došlo k chybě.</mj-text>
        <mj-text>Kontaktuj{{ f ? 'te' : '' }} nás, prosím.</mj-text>
    {% endif %}
{% endblock %}
