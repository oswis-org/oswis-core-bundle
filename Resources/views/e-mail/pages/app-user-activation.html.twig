{% extends '@OswisOrgOswisCore/e-mail/pages/app-user.html.twig' %}

{% block html_title %}{{ email.subject|default('Uživatelský účet') }}{% endblock %}

{% block content_outer %}
    <mj-text>
        {% if type == 'activation-request' %}
            Byl vytvořen {{ f ? 'Váš' : 'Tvůj' }} nový uživatelský účet v aplikaci <b>{{ oswis.app.name }}</b>.
        {% elseif type == 'activation' %}
            {{ f ? 'Váš' : 'Tvůj' }} uživatelský účet v aplikaci <b>{{ oswis.app.name }}</b> byl aktivován.
        {% else %}
            Došlo ke změně u {{ f ? 'Vašeho' : 'Tvého' }} uživatelského účtu v aplikaci <b>{{ oswis.app.name }}</b>.
        {% endif %}
    </mj-text>

    {% if type == 'activation-request' and tokenUrl %}
        <mj-text>
            Ještě je nutné provést aktivaci uživatelského účtu —
            klikni{{ f ? 'te' : '' }} na tlačítko níže:
        </mj-text>
        <mj-button href="{{ tokenUrl }}" background-color="#006FAD" color="#ffffff" font-weight="700" font-size="16px" inner-padding="14px 24px" border-radius="4px">
            Aktivovat účet
        </mj-button>
        <mj-text font-size="11px" color="#666666">
            Pokud tlačítko nefunguje, zkopíruj{{ f ? 'te' : '' }} si tuto adresu do prohlížeče:<br>
            <a href="{{ tokenUrl }}" style="color:#006FAD; word-break:break-all;">{{ tokenUrl }}</a>
        </mj-text>
        {% if appUserToken.validHours|default %}
            <mj-text font-size="11px" color="#888888">
                Odkaz je platný {{ appUserToken.validHours }} hodin od vygenerování.
            </mj-text>
        {% endif %}
    {% endif %}

    <mj-text>
        <strong>Uživatelské jméno</strong>:
        {{ appUser.username|default ? appUser.username|default : appUser.email|default }}<br>
        <strong>Hlavní e-mail</strong>: {{ appUser.email|default }}
    </mj-text>

    {% if appUser.plainPassword|default %}
        <mj-text>Bylo nastaveno nové, náhodně vygenerované heslo:</mj-text>
        <mj-text font-family="monospace" font-size="16px" background-color="#f0f0f0" padding="10px 20px" align="center">
            {{ appUser.plainPassword }}
        </mj-text>
    {% elseif appUser.password|default %}
        <mj-text font-size="12px" color="#666666">
            Heslo bylo nastaveno uživatelem při registraci.
        </mj-text>
    {% else %}
        <mj-text font-size="12px" color="#666666">
            Heslo si nastaví{{ f ? 'te' : 'š' }} při aktivaci účtu.
            Pokud heslo zapomene{{ f ? 'te' : 'š' }}, může{{ f ? 'te' : 'š' }} jej obnovit
            pomocí tlačítka na přihlašovací stránce.
        </mj-text>
    {% endif %}
{% endblock %}
