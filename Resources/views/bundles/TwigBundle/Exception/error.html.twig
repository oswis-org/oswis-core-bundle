{# Web-admin chyby (404/403/500) se musí vykreslit v ADMIN layoutu (admin menu),
   ne ve veřejném — jinak admin klikne na neexistující /web_admin URL a spadne do
   veřejného webu (Informace/Novinky/…). Rozhodujeme dle cesty požadavku; `app.request`
   je v error kontextu dostupný (níž se používá `app.request.requestUri`), `and`
   short-circuituje, kdyby výjimečně nebyl. #}
{% extends (app.request and app.request.pathinfo starts with '/web_admin')
    ? '@OswisOrgOswisCore/web_admin/page-skeleton-web-admin.html.twig'
    : '@OswisOrgOswisCore/web/page-skeleton-default.html.twig' %}

{% block html_title %}{{ block('error_title') }} :: {{ oswis.web.name }}{% endblock %}
{% block html_description %}{{ block('error_content') }}{% endblock %}

{% block body_content %}
    <main class="container" id="main-content-container">
        <div class="row text-justify">
            <div class="col-lg-9">
                <header>
                    <h2 class="text-uppercase">
                        {% block error_title %}
                            Chyba
                        {% endblock error_title %}
                    </h2>
                </header>
                {% block error_content %}
                    <p>V aplikaci nastala chyba. Zkuste to znovu nebo nás kontaktujte.</p>
                {% endblock error_content %}
                <p><small><strong>HTTP {{ status_code }}</strong> {{ status_text }}</small></p>
                <p><small>Požadovaná URL: <strong>{{ app.request.requestUri }}</strong></small></p>
                {# Statický odkaz zpět — v admin layoutu se ESI menu na error stránce nenaplní
                   (role-gated položky + v error kontextu chybí app.user), takže bez tohoto by
                   admin neměl jak zpět. #}
                {% if app.request and app.request.pathinfo starts with '/web_admin' %}
                    <p style="margin-top: 1.25rem;">
                        <a class="btn btn-sm btn-outline-primary"
                           href="{{ path('oswis_org_oswis_core_web_admin_homepage') }}">← Zpět na administraci</a>
                    </p>
                {% endif %}
            </div>
        </div>
    </main>
{% endblock body_content %}

{% block body_breadcrumbs %}
{% endblock body_breadcrumbs %}
